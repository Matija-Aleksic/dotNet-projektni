@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-4">Welcome to Shopping List Manager</h1>
            <p class="lead">Organize your shopping efficiently with our simple and intuitive app.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Shopping Lists</h5>
                    <p class="card-text">Create and manage your shopping lists.</p>
                    <a asp-controller="List" asp-action="Index" class="btn btn-primary w-100">Go to Lists</a>
                    <a asp-controller="List" asp-action="Create" class="btn btn-success w-100 mt-2">New List</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Items</h5>
                    <p class="card-text">Manage items across all your lists.</p>
                    <a asp-controller="Items" asp-action="Index" class="btn btn-primary w-100">Go to Items</a>
                    <a asp-controller="Items" asp-action="Create" class="btn btn-success w-100 mt-2">New Item</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Categories</h5>
                    <p class="card-text">Organize items by categories.</p>
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-primary w-100">Go to Categories</a>
                    <a asp-controller="Categories" asp-action="Create" class="btn btn-success w-100 mt-2">New Category</a>
                </div>
            </div>
        </div>
    </div>
</div>
