@model IEnumerable<ShoppingList>

@{
    ViewData["Title"] = "Shopping Lists";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Shopping Lists</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">Create New List</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No shopping lists found.</div>
    }
    else
    {
        <div class="row">
            @foreach (var list in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@list.Name</h5>
                            <p class="card-text">@list.Description</p>
                            <p class="text-muted">Items: @list.ShoppingListItems?.Count ?? 0</p>
                            <p class="text-muted">Created: @list.CreatedAt.ToString("yyyy-MM-dd")</p>
                            <a asp-action="DetailedList" asp-route-id="@list.ShoppingListId" class="btn btn-sm btn-info">View Details</a>
                            <a asp-action="Edit" asp-route-id="@list.ShoppingListId" class="btn btn-sm btn-warning">Edit</a>
                            <form asp-action="Delete" asp-route-id="@list.ShoppingListId" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

