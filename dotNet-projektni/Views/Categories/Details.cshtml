@model Category

@{
    ViewData["Title"] = "Category Details";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@Model.Name</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </div>

    <h3>Items in this Category</h3>
    @if (!Model.ShoppingListItems?.Any() ?? true)
    {
        <div class="alert alert-info">No items in this category.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Item Name</th>
                        <th>Quantity</th>
                        <th>Unit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ShoppingListItems)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.Unit</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

