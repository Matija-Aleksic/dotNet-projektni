@model Item

@{
    ViewData["Title"] = "Create Item";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1>Create New Item</h1>
            <form asp-controller="Items" asp-action="Create" method="post">
                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label">Item Name</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Quantity" class="form-label">Quantity</label>
                    <input asp-for="Quantity" type="number" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Unit" class="form-label">Unit</label>
                    <input asp-for="Unit" class="form-control" placeholder="e.g., kg, pcs, liters" />
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <div class="form-check">
                        <input asp-for="IsPurchased" type="checkbox" class="form-check-input" />
                        <label asp-for="IsPurchased" class="form-check-label">Purchased</label>
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control">
                        <option value="">Select a category</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ShoppingListId" class="form-label">Shopping List</label>
                    <select asp-for="ShoppingListId" asp-items="ViewBag.ShoppingLists" class="form-control">
                        <option value="">Select a shopping list</option>
                    </select>
                    <span asp-validation-for="ShoppingListId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


