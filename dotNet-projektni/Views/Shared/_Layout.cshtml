<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Curator List</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <!-- Tailwind Config -->
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-tertiary-fixed": "#223457",
                    "surface-container": "#e9eff3",
                    "surface": "#f7fafc",
                    "primary": "#27667d",
                    "outline": "#737c81",
                    "error": "#a83836",
                    "outline-variant": "#aab3b8",
                    "surface-container-highest": "#dbe4e9",
                    "on-surface": "#2b3438",
                    "on-error": "#fff7f6",
                    "on-secondary-fixed": "#2d424b",
                    "error-dim": "#67040d",
                    "on-error-container": "#6e0a12",
                    "surface-bright": "#f7fafc",
                    "tertiary-fixed": "#c0d1fd",
                    "on-background": "#2b3438",
                    "primary-fixed-dim": "#9ad4ef",
                    "on-surface-variant": "#586065",
                    "surface-container-high": "#e2e9ee",
                    "primary-container": "#a7e2fd",
                    "on-primary-fixed": "#003f52",
                    "surface-container-lowest": "#ffffff",
                    "surface-tint": "#27667d",
                    "on-secondary-fixed-variant": "#4a5f68",
                    "tertiary-fixed-dim": "#b2c3ee",
                    "tertiary-container": "#c0d1fd",
                    "on-tertiary": "#f9f8ff",
                    "on-tertiary-container": "#36476b",
                    "secondary-fixed-dim": "#c1d8e3",
                    "secondary-dim": "#415660",
                    "secondary-fixed": "#cfe6f2",
                    "on-tertiary-fixed-variant": "#3f5075",
                    "surface-dim": "#d3dbe1",
                    "inverse-surface": "#0b0f11",
                    "on-secondary": "#f2faff",
                    "background": "#f7fafc",
                    "secondary": "#4d626c",
                    "on-primary-fixed-variant": "#1b5d74",
                    "surface-container-low": "#eff4f8",
                    "tertiary-dim": "#425378",
                    "inverse-primary": "#a7e2fd",
                    "on-primary-container": "#09536a",
                    "surface-variant": "#dbe4e9",
                    "on-primary": "#f2faff",
                    "inverse-on-surface": "#9a9da0",
                    "secondary-container": "#cfe6f2",
                    "tertiary": "#4e5f84",
                    "primary-fixed": "#a7e2fd",
                    "on-secondary-container": "#40555e",
                    "error-container": "#fa746f",
                    "primary-dim": "#165a70"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
    
    <!-- Design System CSS -->
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .tonal-shift {
            background-color: #e9eff3;
        }
        .flat.no-shadows {
            box-shadow: none;
        }
    </style>
</head>
<body class="bg-background font-body text-on-surface min-h-screen">
    <!-- Top Navigation Bar -->
    <header class="w-full h-16 border-b border-transparent bg-surface dark:bg-slate-950 flex items-center justify-between px-12 fixed top-0 z-40">
        <div class="flex items-center gap-8">
            <span class="text-xl font-extrabold tracking-tighter text-on-surface dark:text-slate-100 font-headline">Curator List</span>
        </div>
        <div class="flex items-center gap-6">
            <div class="relative group hidden md:block">
                <span class="material-symbols-outlined text-on-surface-variant absolute left-3 top-1/2 -translate-y-1/2">search</span>
                <input class="bg-surface-container-high border-none rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary w-64 transition-all" placeholder="Quick search..." type="text"/>
            </div>
            <div class="flex gap-4">
                <button class="material-symbols-outlined text-slate-500 hover:bg-slate-100 p-2 rounded-full transition-colors">notifications</button>
                <button class="material-symbols-outlined text-slate-500 hover:bg-slate-100 p-2 rounded-full transition-colors">settings</button>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </header>

    <!-- Side Navigation Bar -->
    <aside class="fixed left-0 top-0 h-screen w-72 flex flex-col bg-surface-container dark:bg-slate-900 flex flex-col py-8 space-y-2 pt-24 hidden md:flex">
        <div class="px-8 mb-8">
            <h2 class="text-lg font-black text-on-surface dark:text-white font-headline">Inventory Hub</h2>
            <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mt-1">The Precision Curator</p>
        </div>
        <nav class="flex-1 space-y-1 px-4">
            <a class="flex items-center gap-3 text-slate-500 dark:text-slate-400 hover:text-primary p-3 mx-2 font-headline font-semibold text-sm transition-all duration-200 ease-in-out hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-lg" asp-area="" asp-controller="List" asp-action="Index">
                <span class="material-symbols-outlined">receipt_long</span>
                Shopping Lists
            </a>
            <a class="flex items-center gap-3 text-slate-500 dark:text-slate-400 hover:text-primary p-3 mx-2 font-headline font-semibold text-sm transition-all duration-200 ease-in-out hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-lg" asp-area="" asp-controller="Items" asp-action="Index">
                <span class="material-symbols-outlined">inventory_2</span>
                Inventory Items
            </a>
            <a class="flex items-center gap-3 text-slate-500 dark:text-slate-400 hover:text-primary p-3 mx-2 font-headline font-semibold text-sm transition-all duration-200 ease-in-out hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-lg" asp-area="" asp-controller="Categories" asp-action="Index">
                <span class="material-symbols-outlined">category</span>
                Categories
            </a>
        </nav>
        <div class="px-6 mb-8">
            <a class="w-full bg-primary text-on-primary py-3 rounded-lg font-semibold flex items-center justify-center gap-2 transition-transform hover:scale-95 duration-150 inline-block" asp-area="" asp-controller="List" asp-action="Create">
                <span class="material-symbols-outlined">add</span>
                Create New
            </a>
        </div>
        <div class="mt-auto px-4 space-y-1">
            <a class="flex items-center gap-3 text-slate-500 dark:text-slate-400 hover:text-primary p-3 mx-2 font-headline font-semibold text-sm transition-all duration-200 ease-in-out hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-lg" href="#">
                <span class="material-symbols-outlined">help</span>
                Help
            </a>
            <a class="flex items-center gap-3 text-slate-500 dark:text-slate-400 hover:text-primary p-3 mx-2 font-headline font-semibold text-sm transition-all duration-200 ease-in-out hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-lg" href="#">
                <span class="material-symbols-outlined">logout</span>
                Logout
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="md:ml-72 pt-16 min-h-screen">
        <div class="p-12 max-w-7xl mx-auto">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="md:ml-72 border-t border-surface-container bg-surface-container-low">
        <div class="p-12 max-w-7xl mx-auto text-center text-on-surface-variant">
            <p>&copy; 2024 - Curator List - Shopping List Manager with Precision Design</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

