@model IEnumerable<Item>

@{
    ViewData["Title"] = "Items";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Items</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">Create New Item</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No items found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Quantity</th>
                        <th>Unit</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.Unit</td>
                            <td>
                                @if (item.IsPurchased)
                                {
                                    <span class="badge bg-success">Purchased</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Not Purchased</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.ItemId" class="btn btn-sm btn-info">View</a>
                                <a asp-action="Edit" asp-route-id="@item.ItemId" class="btn btn-sm btn-warning">Edit</a>
                                <form asp-action="Delete" asp-route-id="@item.ItemId" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

