@model Item

@{
    ViewData["Title"] = "Item Details";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>@Model.Name</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Edit" asp-route-id="@Model.ItemId" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <h5>Quantity:</h5>
                    <p>@Model.Quantity @Model.Unit</p>
                </div>
                <div class="col-md-6">
                    <h5>Status:</h5>
                    <p>
                        @if (Model.IsPurchased)
                        {
                            <span class="badge bg-success">Purchased</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Not Purchased</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

